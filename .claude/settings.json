{
  "mcpServers": {
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\Users\\Park\\OBSv1.0"
      ]
    },
    "fetch": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \".claude\\hooks\\check-commit-branch.ps1\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -File \".claude\\hooks\\check-push-branch.ps1\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -File \".claude\\hooks\\check-destructive-git.ps1\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \".claude\\hooks\\check-commit-branch.ps1\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -File \".claude\\hooks\\check-push-branch.ps1\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -File \".claude\\hooks\\check-destructive-git.ps1\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \".claude\\hooks\\check-ts-ignore.ps1\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \".claude\\hooks\\check-ts-ignore.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \".claude\\hooks\\remind-test-baseline.ps1\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \".claude\\hooks\\remind-test-baseline.ps1\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npm test)",
      "Bash(npm run lint)",
      "Bash(npm run svelte-check)",
      "Bash(npx jest *)",
      "Bash(npx tsc *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git fetch *)",
      "Bash(git diff *)"
    ]
  }
}
