# vscode
.vscode
.history/

# npm
node_modules

# Don't include the compiled main.js file in the repo.
# They should be uploaded to GitHub releases instead.
main.js
!releases/*/main.js

# Exclude sourcemaps
*.map

# obsidian
data.json

# Exclude macOS Finder (System Explorer) View States
.DS_Store

yarn-error.log

# AI internal workspace — lives at workspace level, never inside plugin repo
.ai_internal/
memories/

# CRITICAL: Personal Data Protection
OBScync/
EMERGENCY-BACKUPS/
personal-*
*-vault/
!demo-vault/
# Allow the demo vault plugin data (stripped of personal paths)
!demo-vault/.obsidian/
!demo-vault/.obsidian/plugins/
!demo-vault/.obsidian/plugins/obs-projects-plus/
!demo-vault/.obsidian/plugins/obs-projects-plus/data.json
!demo-vault/.obsidian/community-plugins.json
*.personal

# Ephemeral dev/debug dumps (never commit)
_git_log.txt
failures.txt
ts_errors.txt
lint_output*.txt
/RELEASE_NOTES.md

# Recovery bundles
*.bundle

# Local-only Claude Code legacy (no longer used; safety guard if it returns)
.claude/

# .vscode/mcp.json contains personal absolute paths and env-var refs — local only.
# .vscode itself is already gitignored above; no extra rule needed here.

# Internal AI agent configuration — local only, not for public repos.
# These contain internal tooling details and workflow prompts.
.github/agents/
.github/prompts/
.github/instructions/
.github/README.md

# Internal session state — changes every session, not for public tracking.
docs/internal/CONTEXT.md
